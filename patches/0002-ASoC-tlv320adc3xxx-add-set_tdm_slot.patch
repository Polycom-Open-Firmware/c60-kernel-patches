From a70451c10af77a9c98b1af7fa7336d9221a2de6d Mon Sep 17 00:00:00 2001
From: acamilo <Alex.Camilo@gmail.com>
Date: Wed, 13 May 2026 18:47:47 -0400
Subject: [PATCH 2/4] ASoC: tlv320adc3xxx: implement set_tdm_slot for
 multi-codec TDM
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

The tlv320adc3001/3101 DAI ops table currently has no .set_tdm_slot
handler. When the codec is used as one of N codecs sharing a single TDM
bus, the DT-supplied dai-tdm-slot-rx-mask reaches
snd_soc_dai_set_tdm_slot() which returns -ENOTSUPP (silently absorbed
by asoc_simple_set_tdm()), so every chip keeps its default CH_OFFSET_1
of 0 and drives slots 0,1 of the frame — collisions on the data line.

Add an .set_tdm_slot op that:

  - finds the lowest set bit in rx_mask as the chip's first slot,
  - validates that rx_mask sets at most channels_max (2) bits and that
    the bits are contiguous (the chip captures one stereo pair),
  - validates slots (1..32) and slot_width (16/20/24/32),
  - rejects values where first_slot * slot_width would overflow the
    8-bit CH_OFFSET_1 register,
  - stores first_slot and slot_width in struct adc3xxx so hw_params()
    can program CH_OFFSET_1 = first_slot * slot_width (datasheet: bit
    offset, not slot index — hence the multiplication).

tx_mask is accepted but ignored; the chip is an ADC and has no
transmit path, but asoc_simple_set_tdm() always passes both masks.

If .set_tdm_slot is never called (single-codec I2S use, no per-codec
TDM slot mask in DT) tdm_slot_width stays 0 and hw_params() skips the
CH_OFFSET_1 write — preserving existing behaviour for current users.
---
 sound/soc/codecs/tlv320adc3xxx.c | 95 ++++++++++++++++++++++++++++++++
 1 file changed, 95 insertions(+)

diff --git a/sound/soc/codecs/tlv320adc3xxx.c b/sound/soc/codecs/tlv320adc3xxx.c
index 420bbf588..53c063138 100644
--- a/sound/soc/codecs/tlv320adc3xxx.c
+++ b/sound/soc/codecs/tlv320adc3xxx.c
@@ -326,6 +326,11 @@ struct adc3xxx {
 	int master;
 	u8 page_no;
 	int use_pll;
+	/* TDM slot programming via .set_tdm_slot (default: slot 0 of frame,
+	 * which matches stock single-codec I2S behaviour).
+	 */
+	unsigned int tdm_first_slot;
+	unsigned int tdm_slot_width;
 	struct gpio_chip gpio_chip;
 };
 
@@ -1210,6 +1215,95 @@ static int adc3xxx_hw_params(struct snd_pcm_substream *substream,
 	snd_soc_component_update_bits(component, ADC3XXX_BCLK_N_DIV,
 				      ADC3XXX_BDIV_MASK, bdiv);
 
+	/*
+	 * Program TDM slot offset for this chip's capture pair. By default
+	 * (tdm_first_slot == 0, tdm_slot_width == 0) this is a no-op and the
+	 * chip drives slots 0,1 of the frame — matching pre-set_tdm_slot
+	 * behaviour. .set_tdm_slot() populates these fields from DT-supplied
+	 * dai-tdm-slot-rx-mask so multiple codecs can share a TDM bus without
+	 * stomping on each other.
+	 */
+	if (adc3xxx->tdm_slot_width)
+		snd_soc_component_write(component, ADC3XXX_CH_OFFSET_1,
+					adc3xxx->tdm_first_slot *
+					adc3xxx->tdm_slot_width);
+
+	return 0;
+}
+
+static int adc3xxx_set_tdm_slot(struct snd_soc_dai *dai,
+				unsigned int tx_mask, unsigned int rx_mask,
+				int slots, int slot_width)
+{
+	struct snd_soc_component *component = dai->component;
+	struct adc3xxx *adc3xxx = snd_soc_component_get_drvdata(component);
+	unsigned int first_slot, last_slot, hweight;
+
+	/*
+	 * This driver only supports stereo capture (channels_max = 2), so
+	 * rx_mask must encode at most two contiguous TDM slots. tx_mask is
+	 * unused — the chip is an ADC, but accept whatever the framework
+	 * passes (asoc_simple_set_tdm() always sets both).
+	 */
+	if (!rx_mask) {
+		dev_err(component->dev, "set_tdm_slot: empty rx_mask\n");
+		return -EINVAL;
+	}
+
+	hweight = hweight32(rx_mask);
+	if (hweight > 2) {
+		dev_err(component->dev,
+			"set_tdm_slot: rx_mask 0x%x has %u bits; chip captures 2 channels max\n",
+			rx_mask, hweight);
+		return -EINVAL;
+	}
+
+	first_slot = __ffs(rx_mask);
+	last_slot = fls(rx_mask) - 1;
+	if (last_slot - first_slot + 1 != hweight) {
+		dev_err(component->dev,
+			"set_tdm_slot: rx_mask 0x%x slots must be contiguous\n",
+			rx_mask);
+		return -EINVAL;
+	}
+
+	if (slots <= 0 || slots > 32) {
+		dev_err(component->dev,
+			"set_tdm_slot: slots=%d out of range (1..32)\n", slots);
+		return -EINVAL;
+	}
+
+	switch (slot_width) {
+	case 16:
+	case 20:
+	case 24:
+	case 32:
+		break;
+	default:
+		dev_err(component->dev,
+			"set_tdm_slot: slot_width=%d unsupported (16/20/24/32)\n",
+			slot_width);
+		return -EINVAL;
+	}
+
+	if ((u64)first_slot * slot_width > 255) {
+		/*
+		 * CH_OFFSET_1 is an 8-bit register — bit offset must fit in
+		 * 0..255 (datasheet: up to 8 channels @ 32-bit slots).
+		 */
+		dev_err(component->dev,
+			"set_tdm_slot: first_slot=%u * slot_width=%d overflows CH_OFFSET_1\n",
+			first_slot, slot_width);
+		return -EINVAL;
+	}
+
+	adc3xxx->tdm_first_slot = first_slot;
+	adc3xxx->tdm_slot_width = slot_width;
+
+	dev_dbg(component->dev,
+		"set_tdm_slot: rx_mask=0x%x -> first_slot=%u slot_width=%d (ch_offset_1=%u)\n",
+		rx_mask, first_slot, slot_width, first_slot * slot_width);
+
 	return 0;
 }
 
@@ -1316,6 +1410,7 @@ static const struct snd_soc_dai_ops adc3xxx_dai_ops = {
 	.hw_params	= adc3xxx_hw_params,
 	.set_sysclk	= adc3xxx_set_dai_sysclk,
 	.set_fmt	= adc3xxx_set_dai_fmt,
+	.set_tdm_slot	= adc3xxx_set_tdm_slot,
 };
 
 static struct snd_soc_dai_driver adc3xxx_dai = {
-- 
2.34.1

